    <!-- Números -->
    <string name="numbers_title">El Sistema Matemático Moche</string>
    <string name="numbers_subtitle">Un sistema de cuenta altamente avanzado. Los mochicas no decían simplemente «veinte hombres»… utilizaban un clasificador que lo indicaba todo.</string>
    <string name="numbers_formula_label">Fórmula constructiva:</string>
    <string name="numbers_prefixes_title">1. Los Prefijos Base (De 10 en 10)</string>
    <string name="numbers_age_title">Aplicación: Preguntar la Edad</string>
    <string name="numbers_age_question_muchik">¿Ep æn fûr æn chefnam az?</string>
    <string name="numbers_age_question_spanish">¿Cuántos años tienes?</string>
    <string name="numbers_age_example">«Pac ssop fûr æn» → Veinte años</string>
    <string name="numbers_age_note">* Usa «ssop» porque los años se cuentan como frutos o ciclos.</string>
    <string name="numbers_practical_title">Ejemplo práctico: 12 hombres</string>
    <string name="numbers_practical_result">→ «Napong allo atput ñofæn» — «Diez personas y dos hombres»</string>
